{
	"luci-proto-amneziawg": {
		"description": "Grant access to LuCI AmneziaWG procedures",
		"read": {
			"ubus": {
				"luci.amneziawg": [
					"getAwgInstances",
					"getAwgTraffic"
				]
			},
			"uci": [ "ddns", "system", "network" ],
			"file": [ "/sys/class/net/*/statistics/*" ]
		},
		"write": {
			"ubus": {
				"luci.amneziawg": [
					"generateKeyPair",
					"getPublicAndPrivateKeyFromPrivate",
					"generatePsk"
				]
			}
		}
	}
}
