# AmneziaWG packages
CONFIG_PACKAGE_kmod-amneziawg=m
CONFIG_PACKAGE_amneziawg-tools=y
CONFIG_PACKAGE_luci-proto-amneziawg=y

# Crypto libraries required by AmneziaWG
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=m
CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=m
CONFIG_PACKAGE_kmod-crypto-chacha20poly1305=m
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=m

# Networking tools
CONFIG_PACKAGE_ethtool=m
CONFIG_PACKAGE_ethtool-full=m

# Kernel options required by kmod-amneziawg
CONFIG_NET_UDP_TUNNEL=m
CONFIG_INET_UDP_DIAG=m
CONFIG_INET6_UDP_DIAG=m
CONFIG_CRYPTO_CURVE25519_GENERIC=y
CONFIG_CRYPTO_CURVE25519=y
CONFIG_NET_IPVTI=y
CONFIG_IPV6_VTI=y
CONFIG_DNS_RESOLVER=y
CONFIG_NF_CONNTRACK_EVENTS=y

# BPI-R4 device selection
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_bananapi_bpi-r4=y
CONFIG_TARGET_mediatek_filogic_DEVICE_bananapi_bpi-r4=y
CONFIG_PACKAGE_u-boot-mt7988_bananapi_bpi-r4-emmc=y
CONFIG_PACKAGE_u-boot-mt7988_bananapi_bpi-r4-sdmmc=y
CONFIG_PACKAGE_u-boot-mt7988_bananapi_bpi-r4-snand=y
CONFIG_TARGET_BOARD=mediatek
CONFIG_TARGET_PROFILE=DEVICE_bananapi_bpi-r4
CONFIG_HAS_SUBTARGETS=y
CONFIG_TARGET_SUBTARGET=filogic
